{
    "mcpServers" : {
        "playwright" : {
            "command" : "npx" ,
            "args" : [
                "@playwright/mcp@latest" ,
                "--browser" ,
                "chromium" ,
                "--isolated" ,
                "--no-sandbox"
            ]
        },
        "supabase" : {
            "command" : "npx" ,
            "args" : [
                "-y" ,
                "@supabase/mcp-server-supabase@latest"
            ],
            "env" : {
                "SUPABASE_ACCESS_TOKEN" : "${SUPABASE_ACCESS_TOKEN}"
            }
        }
    }
}